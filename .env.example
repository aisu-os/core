# Application
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://aisu:aisu@localhost:5432/aisu

# Auth (MAJBURIY: production uchun xavfsiz kalit yarating)
# Generatsiya: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BETA_ACCESS_ENABLED=true
BETA_REGISTER_URL=http://localhost:5174/register
BETA_TOKEN_EXPIRE_HOURS=72

# SMTP (beta invite email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@aisu.local
SMTP_USE_TLS=true

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Server
HOST=0.0.0.0
PORT=8890

# Port Forward / Caddy
CADDY_ADMIN_URL=
PORT_FORWARD_DOMAIN=t.localhost
PORT_FORWARD_SCHEME=http
CADDY_TLS_CERT=
CADDY_TLS_KEY=
